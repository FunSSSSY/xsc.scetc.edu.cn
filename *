    function getNowFormatDate() {
        var day = new Date();

        var Year = 0;
        var Month = 0;
        var Day = 0;
        var CurrentDate = "";
        //初始化时间   
        Year = day.getFullYear();
        Month = day.getMonth() + 1;
        Day = day.getDate();

        CurrentDate += Year + "-";

        if (Month >= 10) {
            CurrentDate += Month + "-";
        }
        else {
            CurrentDate += "0" + Month + "-";
        }
        if (Day >= 10) {
